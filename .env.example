PORT=3000
NODE_ENV=development
DATABASE_PATH=./data/clinic.db
JWT_SECRET=change-me-in-real-environments
# Optional — access vs refresh lifetimes (see `src/config/env.js`)
# JWT_EXPIRES_IN=1h
# JWT_REFRESH_EXPIRES_IN=7d

# Logging (Pino): trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
# Pretty stdout in development (needs devDependency pino-pretty): true | false
# LOG_PRETTY=true

# AI recommendation (see `src/routes/aiRoutes.js`)
# ENABLE_AI_RECOMMENDATION=true
# AI_RATE_LIMIT_WINDOW_MS=60000
# AI_RATE_LIMIT_MAX=5

# Rate limits — login / register / booking (see `src/middlewares/rate-limit.js`)
# Lower these in tests to trigger 429 quickly (e.g. RATE_LIMIT_LOGIN_MAX=2 RATE_LIMIT_LOGIN_WINDOW_MS=5000)
# RATE_LIMIT_LOGIN_WINDOW_MS=900000
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_REGISTER_WINDOW_MS=3600000
# RATE_LIMIT_REGISTER_MAX=5
# RATE_LIMIT_BOOKING_WINDOW_MS=60000
# RATE_LIMIT_BOOKING_MAX=20

# Behind reverse proxy / Docker ingress — correct client IP for rate limits
# TRUST_PROXY=false

# Optional: cancel very old pending appointments on a timer (0 = disabled)
# AUTO_EXPIRE_PENDING_INTERVAL_MS=0
# AUTO_EXPIRE_PENDING_MAX_AGE_MS=604800000

# Development-only: POST /api/v1/debug/simulate-concurrent-booking
# ENABLE_DEBUG_ROUTES=false

# Chaos mode: inject random 503s and latency on /api/v1 routes (see src/middlewares/chaos.js)
# CHAOS_ENABLED=false
# CHAOS_FAIL_PROBABILITY=0.2
# CHAOS_LATENCY_MS=0
# CHAOS_SEED=

# Webhook notifications — POST appointment status-change events to this URL (omit to disable)
# WEBHOOK_URL=http://localhost:9001

# Online consultations payment mode: disabled | mock_success | mock_fail (default: disabled)
# PAYMENT_MODE=mock_success
